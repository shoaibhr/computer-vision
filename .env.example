# Video source: RTSP URL, webcam index (e.g. 0), or path to a video file
SOURCE=rtsp://username:password@192.168.x.x:554/Streaming/Channels/102

# Legacy alias for SOURCE (still supported)
# RTSP_URL=rtsp://...

# Detection zones. Comma-separated boxes, each "name:x1,y1,x2,y2" (name optional).
# Multiple zones: ZONES=entrance:118,6,218,206;loading-dock:300,50,500,400
ZONES=entrance:118,6,218,206

# Legacy single-ROI variables (still supported if ZONES is unset)
# ROI_X1=118
# ROI_Y1=6
# ROI_X2=218
# ROI_Y2=206

# Detection backend: "opencv" (YOLOv4-tiny, auto-downloaded) or "ultralytics"
# (requires `pip install zonewatch[yolo]`)
BACKEND=opencv

# Ultralytics model name or path (only used with BACKEND=ultralytics)
# MODEL=yolov8n.pt

# Minimum detection confidence (0-1)
CONFIDENCE=0.5

# Run detection every Nth frame (higher = faster, less responsive)
DETECT_EVERY=1

# Consecutive detection frames before an ENTER event fires / clears
ENTER_FRAMES=3
EXIT_FRAMES=15

# Optional: POST a JSON payload to this URL on zone enter/exit events
# WEBHOOK_URL=https://example.com/hooks/zonewatch

# Optional: save an annotated snapshot on zone entry to this directory
# SNAPSHOT_DIR=snapshots

# Minimum seconds between notifications per zone
COOLDOWN=30

# Set to "true" to disable the preview window (for servers / Docker)
HEADLESS=false

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
